[Unit]
Description=BirdEngine Recording — Audio capture
After=sound.target birdash.service
Wants=birdash.service

[Service]
Type=simple
User=BIRDASH_USER
ExecStart=BIRDASH_HOME/birdash/engine/record.sh
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
